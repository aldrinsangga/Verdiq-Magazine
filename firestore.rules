rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email.lower() == "verdiqmag@gmail.com" && request.auth.token.email_verified == true) ||
          request.auth.token.email.lower() == "server-internal@verdiq.ai" ||
          request.auth.token.email.lower() == "server-internal-v2@verdiq.ai" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isServer() {
      return isAuthenticated() && 
        (
          request.auth.token.email.lower() == "server-internal@verdiq.ai" || 
          request.auth.token.email.lower() == "server-internal-v2@verdiq.ai" ||
          request.auth.token.email.lower() == "verdiqmag@gmail.com"
        );
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isServer();
      allow create: if isOwner(userId) || isAdmin() || isServer();
      allow update: if (isOwner(userId) && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'credits', 'isUnlimited', 'isSubscribed'])) || 
                      isAdmin() || isServer();
      allow delete: if isAdmin() || isServer();
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if (resource.data.isPublished == true) || (isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isServer()));
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin() || isServer());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isServer());
      allow delete: if isAdmin() || isServer();
    }

    // Purchases Collection
    match /purchases/{purchaseId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isServer());
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isServer();
      allow delete: if isAdmin() || isServer();
    }

    // Style Guides Collection
    match /styleGuides/{guideId} {
      allow read: if isAdmin() || isServer();
      allow write: if isAdmin() || isServer();
    }

    // Magazine Articles Collection
    match /magazine/{articleId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() || isServer();
    }

    // Podcast Episodes Collection
    match /podcasts/{episodeId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() || isServer();
    }

    // Support Tickets Collection
    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || isServer();
      allow create: if true; // Anyone can create a support ticket
      allow update: if isAdmin() || isServer();
      allow delete: if isAdmin() || isServer();
    }

    // Referrals Collection
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.referrerId || isAdmin() || isServer());
      allow create: if isAdmin() || isServer();
      allow update: if isAdmin() || isServer();
      allow delete: if isAdmin() || isServer();
    }
    
    // Stats Collection
    match /stats/{statId} {
      allow read: if isAdmin() || isServer();
      allow write: if isAdmin() || isServer();
    }
    
    // Assets Collection
    match /assets/{assetId} {
      allow read: if true; // Publicly readable
      allow write: if isAuthenticated(); // Allow authenticated users to save global assets (like the jingle)
    }
    
    // Health Check
    match /health_check/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
