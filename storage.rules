rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public assets folder
    match /assets/{allPaths=**} {
      allow read: if true;
    }
    
    // Reviews and user data - authenticated only
    match /podcasts/{allPaths=**} {
      allow read: if true; // Allow public listening to podcasts
      allow write: if request.auth != null;
    }
    
    match /songs/{allPaths=**} {
      allow read: if true; // Allow public listening to songs
      allow write: if request.auth != null;
    }
    
    match /images/{allPaths=**} {
      allow read: if true; // Allow public viewing of review images
      allow write: if request.auth != null;
    }

    match /artist_photos/{allPaths=**} {
      allow read: if true; // Allow public viewing of artist photos
      allow write: if request.auth != null;
    }
    
    // Default: Authenticated
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
