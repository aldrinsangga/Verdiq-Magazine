{
  "entities": {
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "A support request from the contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "credits": { "type": "integer" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "mfaEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" }
      },
      "required": ["id", "email", "name", "credits", "role"]
    },
    "Referral": {
      "title": "Referral",
      "description": "A record of a user referral",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referrerId": { "type": "string" },
        "referredId": { "type": "string" },
        "referredName": { "type": "string" },
        "referredEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["signed_up", "completed"] },
        "creditsAwarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "referrerId", "referredId", "status", "creditsAwarded", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A track review generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "songTitle": { "type": "string" },
        "artistName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "headline": { "type": "string" },
        "hook": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "hasPodcast": { "type": "boolean" }
      },
      "required": ["id", "userId", "songTitle", "artistName", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Credit purchase record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "credits": { "type": "integer" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "credits", "status", "createdAt"]
    },
    "StyleGuide": {
      "title": "Style Guide",
      "description": "Reference article for AI style training",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source": { "type": "string" },
        "type": { "type": "string", "enum": ["article", "review", "blog"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "type", "createdAt"]
    },
    "MagazineArticle": {
      "title": "Magazine Article",
      "description": "Editorial content for VERDIQ magazine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "readTime": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "slug": { "type": "string" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["id", "title", "content", "author", "createdAt", "slug"]
    },
    "PodcastEpisode": {
      "title": "Podcast Episode",
      "description": "Audio review episode for VERDIQ SESSIONS",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "audioUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "duration": { "type": "string" },
        "playCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "guest": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "audioUrl", "playCount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Track review documents"
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Global purchase records for earnings tracking"
    },
    "/styleGuides/{guideId}": {
      "schema": "StyleGuide",
      "description": "Reference articles for AI style training"
    },
    "/magazine/{articleId}": {
      "schema": "MagazineArticle",
      "description": "Magazine articles"
    },
    "/podcasts/{episodeId}": {
      "schema": "PodcastEpisode",
      "description": "Podcast episodes"
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "User support requests"
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "User referral records"
    }
  }
}
