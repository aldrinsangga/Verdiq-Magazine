{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "credits": { "type": "integer" },
        "isSubscribed": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "mfaEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "credits", "isSubscribed", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A track review generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "songTitle": { "type": "string" },
        "artistName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "headline": { "type": "string" },
        "hook": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "hasPodcast": { "type": "boolean" }
      },
      "required": ["id", "userId", "songTitle", "artistName", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Subscription invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "amount": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Pending"] },
        "plan": { "type": "string" }
      },
      "required": ["id", "date", "amount", "status", "plan"]
    },
    "StyleGuide": {
      "title": "Style Guide",
      "description": "Reference article for AI style training",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source": { "type": "string" },
        "type": { "type": "string", "enum": ["article", "review", "blog"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "type", "createdAt"]
    },
    "MagazineArticle": {
      "title": "Magazine Article",
      "description": "Editorial content for VERDIQ magazine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "readTime": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "slug": { "type": "string" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["id", "title", "content", "author", "createdAt", "slug"]
    },
    "PodcastEpisode": {
      "title": "Podcast Episode",
      "description": "Audio review episode for VERDIQ SESSIONS",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "audioUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "duration": { "type": "string" },
        "playCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "guest": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "audioUrl", "playCount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Track review documents"
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User invoices"
    },
    "/styleGuides/{guideId}": {
      "schema": "StyleGuide",
      "description": "Reference articles for AI style training"
    },
    "/magazine/{articleId}": {
      "schema": "MagazineArticle",
      "description": "Magazine articles"
    },
    "/podcasts/{episodeId}": {
      "schema": "PodcastEpisode",
      "description": "Podcast episodes"
    }
  }
}
